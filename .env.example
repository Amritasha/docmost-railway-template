# Required
APP_URL=https://your-app.up.railway.app
APP_SECRET=                          # Generate: openssl rand -hex 32
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# Optional
PORT=3000
NODE_ENV=production
DISABLE_TELEMETRY=true
FILE_UPLOAD_SIZE_LIMIT=50mb
FILE_IMPORT_SIZE_LIMIT=200mb
JWT_TOKEN_EXPIRES_IN=90d

# Email (optional — needed for invites/password reset)
MAIL_DRIVER=smtp
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Docmost
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false

# S3 Storage (optional — replaces local volume storage)
# STORAGE_DRIVER=s3
# AWS_S3_ACCESS_KEY_ID=
# AWS_S3_SECRET_ACCESS_KEY=
# AWS_S3_REGION=us-east-1
# AWS_S3_BUCKET=
# AWS_S3_ENDPOINT=
